rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Promos collection — each user can only read/write their own documents
    match /promos/{promoId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Saved Promoters — each user can only manage their own saved promoters
    match /savedPromoters/{promoterId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Saved Accounts — each user can only manage their own saved accounts
    match /savedAccounts/{accountId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
